# Rust
/target
# Guest fixture crates build into their own nested target/ dirs (we check in only
# the prebuilt .wasm, not the build output).
crates/rusm-wasm/tests/fixtures/*/target/
crates/rusm-wasm/js-runner/target/
# Example apps build their components into a local wasm/ dir (checked-in source only).
examples/*/wasm/
**/*.rs.bk
*.profraw

# Coverage
/coverage
/lcov.info

# Node / Bun (we use Bun, never npm/Node — but ignore both ecosystems' artifacts)
node_modules
dist
.vite
*.tsbuildinfo

# VitePress build cache (the published site under docs/.vitepress/dist is committed)
docs/.vitepress/cache

# OS / editor
.DS_Store
*.swp
