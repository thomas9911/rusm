# Rust
/target
# Nested standalone crates (guest fixtures, the rquickjs runners, the guest libs)
# each build into their OWN target/ — never check in build output, only the
# prebuilt .wasm. The catch-all stops a new nested crate leaking its target/ again
# (e.g. rquickjs-sys downloads a ~100MB wasi-sdk into its build dir).
**/target/
crates/rusm-wasm/tests/fixtures/*/target/
crates/rusm-wasm/js-runner/target/
crates/rusm-wasm/js-http-runner/target/
crates/rusm-rs/target/
crates/rusm-rs-macros/target/
# Example apps build their components into a local wasm/ dir (checked-in source only).
examples/*/wasm/
**/*.rs.bk
*.profraw

# Coverage
/coverage
/lcov.info

# Node / Bun (we use Bun, never npm/Node — but ignore both ecosystems' artifacts)
node_modules
dist
.vite
*.tsbuildinfo

# VitePress build cache (the published site under docs/.vitepress/dist is committed)
docs/.vitepress/cache

# OS / editor
.DS_Store
*.swp

# Claude Code local session state, plans, and settings (machine-local, not shared).
.claude/
