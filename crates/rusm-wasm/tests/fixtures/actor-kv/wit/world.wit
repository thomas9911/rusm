package rusm:runtime@0.1.0;

/// Minimal actor subset for the `kv-*` fixture: the handshake ops plus durable
/// key-value storage. (The full interface lives in the host + SDK wits.)
interface actor {
    /// A process identifier (Erlang's pid).
    type pid = u64;

    /// This process's own pid (Erlang's `self()`).
    own-pid: func() -> pid;

    /// Send a byte message to another process; silently dropped if it's gone.
    send: func(to: pid, message: list<u8>);

    /// Receive the next message, suspending until one arrives (FIFO).
    receive: func() -> list<u8>;

    /// Durable key-value storage, gated by the `storage` capability.
    kv-get: func(bucket: string, key: string) -> result<option<list<u8>>, string>;
    kv-set: func(bucket: string, key: string, value: list<u8>) -> result<_, string>;
    kv-delete: func(bucket: string, key: string) -> result<bool, string>;
    kv-exists: func(bucket: string, key: string) -> result<bool, string>;
    kv-list: func(bucket: string) -> result<list<string>, string>;
}

world process {
    import actor;
    export run: func();
}
